# PC Bottleneck Analyzer - Environment Variables
# Copy this file to .env.local and fill in values

# Anthropic Claude API Key (required for Session 3+ AI analysis features)
ANTHROPIC_API_KEY=

# Lemon Squeezy (Pro payments)
# Get your checkout URL from: app.lemonsqueezy.com > Store > Products > [your product] > Share
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=
# Get your webhook secret from: app.lemonsqueezy.com > Settings > Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=
